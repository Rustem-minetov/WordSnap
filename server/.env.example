# Server Configuration
PORT=3000
NODE_ENV=development

# DeepL API
# Get your key at https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here

# Firebase Admin SDK (via Environment Variables)
# Get these from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_client_email@project.iam.gserviceaccount.com

# Firebase Client Configuration (for Frontend/Extension)
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
